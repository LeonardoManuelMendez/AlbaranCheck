      <packagedElement xmi:type="uml:Class" xmi:id="_Jb7ukA_mEfCa2eeoRS-vlw" name="InicialConLogo">
        <ownedComment xmi:id="_JmWO1A_mEfCa2eeoRS-vlw">
          <body>*
@author Leonardo Méndez</body>
        </ownedComment>
        <generalization xmi:id="_JlGRoA_mEfCa2eeoRS-vlw" general="_JcGtsA_mEfCa2eeoRS-vlw"/>
        <ownedAttribute xmi:id="_Jl0DUg_mEfCa2eeoRS-vlw" name="serialVersionUID" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#long"/>
          <defaultValue xmi:type="uml:LiteralString" xmi:id="_Jl0DUw_mEfCa2eeoRS-vlw" value="1L"/>
        </ownedAttribute>
        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_JmPhIA_mEfCa2eeoRS-vlw" name="InicialConLogo" specification="_Jb8VoA_mEfCa2eeoRS-vlw">
          <ownedParameter xmi:id="_JmPhIQ_mEfCa2eeoRS-vlw" type="_Jb7ukA_mEfCa2eeoRS-vlw" direction="return"/>
          <language>java</language>
          <body>setBackground(Color.WHITE);
     setBorder(BorderFactory.createLineBorder(Color.BLACK));
     
     JLabel saludo = new JLabel(&quot;Bienvenidos!!!&quot;);

     // Carga la imagen
     ImageIcon imagenIcono = new ImageIcon(&quot;./src/ficheros/logo.png&quot;);       
   

     // Escala la imagen si es necesario (opcional)
     Image imagen = imagenIcono.getImage().getScaledInstance(270, 200, Image.SCALE_SMOOTH);
     imagenIcono = new ImageIcon(imagen);

     // Crea un JLabel y establece la imagen
     JLabel etiquetaImagen = new JLabel(imagenIcono);

     // crea una instacia para la disposición de los objetos dentro del panel
     BorderLayout layout = new BorderLayout();
     this.setLayout(layout);
     
     add(saludo, BorderLayout.NORTH);
     add(etiquetaImagen, BorderLayout.CENTER);
     
   
     
 </body>
        </ownedBehavior>
        <ownedOperation xmi:id="_Jb8VoA_mEfCa2eeoRS-vlw" name="InicialConLogo" method="_JmPhIA_mEfCa2eeoRS-vlw">
          <eAnnotations xmi:id="_Jb8VoQ_mEfCa2eeoRS-vlw" source="http://www.eclipse.org/uml2/2.0.0/UML">
